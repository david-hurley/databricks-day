{
  "datasets": [
    {
      "name": "summary_kpis",
      "displayName": "Summary KPIs",
      "queryLines": [
        "SELECT COUNT(*) as total_observations, COUNT(DISTINCT POSTAL_CODE) as unique_locations, ROUND(AVG(temperature_avg), 1) as avg_temp, ROUND(AVG(precipitation_probability), 1) as avg_precip_prob, ROUND(AVG(humidity_relative_avg), 1) as avg_humidity, ROUND(AVG(wind_speed_avg), 1) as avg_wind FROM classic_stable_been2c_catalog.weather.us_postal_daily_metric"
      ]
    },
    {
      "name": "daily_trends",
      "displayName": "Daily Trends",
      "queryLines": [
        "SELECT date, ROUND(AVG(temperature_avg), 1) as avg_temp, ROUND(AVG(temperature_max), 1) as avg_high, ROUND(AVG(temperature_min), 1) as avg_low, ROUND(AVG(precipitation_probability), 1) as avg_precip_prob, ROUND(AVG(humidity_relative_avg), 1) as avg_humidity, ROUND(AVG(wind_speed_avg), 1) as avg_wind_speed FROM classic_stable_been2c_catalog.weather.us_postal_daily_metric GROUP BY date ORDER BY date"
      ]
    },
    {
      "name": "weather_conditions",
      "displayName": "Weather Conditions",
      "queryLines": [
        "SELECT phrase_short as weather_condition, COUNT(*) as observation_count FROM classic_stable_been2c_catalog.weather.us_postal_daily_metric WHERE phrase_short IS NOT NULL GROUP BY phrase_short ORDER BY observation_count DESC LIMIT 8"
      ]
    },
    {
      "name": "map_data",
      "displayName": "Temperature Map Data",
      "queryLines": [
        "SELECT ROUND(latitude, 0) as latitude, ROUND(longitude, 0) as longitude, ROUND(AVG(temperature_avg), 1) as avg_temp, ROUND(AVG(precipitation_probability), 1) as avg_precip_prob, COUNT(*) as obs_count FROM classic_stable_been2c_catalog.weather.us_postal_daily_metric WHERE date = (SELECT MAX(date) FROM classic_stable_been2c_catalog.weather.us_postal_daily_metric) GROUP BY ROUND(latitude, 0), ROUND(longitude, 0) HAVING COUNT(*) > 20 ORDER BY obs_count DESC"
      ]
    }
  ],
